{
  "type": "container",
  "content": {
    "backgroundColor": "clear",
    "padding": {
      "top": "large",
      "leading": "large",
      "bottom": "large",
      "trailing": "large"
    }
  },
  "subviews": [
    {
      "type": "stack",
      "content": {
        "axis": "vertical",
        "spacing": "large",
        "alignment": "fill"
      },
      "subviews": [
        {
          "type": "image",
          "content": {
            "icon": "playlist",
            "backgroundColor": "primary",
            "cornerRadius": "large",
            "width": 180,
            "height": 180
          }
        },
        {
          "type": "label",
          "content": {
            "text": "Backend Driven UI",
            "textStyle": "heroTitle"
          }
        },
        {
          "type": "label",
          "content": {
            "text": "Экран собран целиком из JSON-конфига через generic mapper и дизайн-систему.",
            "textStyle": "body"
          }
        },
        {
          "type": "container",
          "content": {
            "backgroundColor": "surfaceElevated",
            "cornerRadius": "regular",
            "padding": {
              "top": "large",
              "leading": "large",
              "bottom": "large",
              "trailing": "large"
            }
          },
          "subviews": [
            {
              "type": "stack",
              "content": {
                "axis": "vertical",
                "spacing": "medium"
              },
              "subviews": [
                {
                  "type": "label",
                  "content": {
                    "text": "Что умеет этот экран",
                    "textStyle": "bodyStrong"
                  }
                },
                {
                  "type": "label",
                  "content": {
                    "text": "Контейнеры, stack view, label, button, image и spacer задаются одной декодируемой моделью.",
                    "textStyle": "subheadline"
                  }
                }
              ]
            }
          ]
        },
        {
          "type": "spacer",
          "content": {
            "height": 8
          }
        },
        {
          "type": "button",
          "content": {
            "text": "Вывести action в консоль",
            "buttonStyle": "primary",
            "action": {
              "type": "print",
              "message": "BDUI button tapped"
            }
          }
        },
        {
          "type": "button",
          "content": {
            "text": "Перезагрузить экран",
            "buttonStyle": "secondary",
            "action": {
              "type": "reload"
            }
          }
        }
      ]
    }
